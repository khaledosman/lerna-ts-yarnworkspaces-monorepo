{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "rimraf ./lib && tsc",
    "start": "nodemon",
    "publish": "lerna run tsc && lerna publish",
    "commitmsg": "commitlint -e $GIT_PARAMS",
    "commit": "npx git-cz",
    "release": "lerna run tsc --parallel && lerna publish"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npx standardx packages/**/*.ts src/**/*.ts --fix",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "standardx": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint/eslint-plugin"
    ]
  },
  "standard": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint/eslint-plugin"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^11.0.0",
    "@commitlint/config-conventional": "^11.0.0",
    "@types/node": "^14.11.5",
    "@typescript-eslint/eslint-plugin": "^4.4.0",
    "@typescript-eslint/parser": "^4.4.0",
    "husky": "^4.3.0",
    "lerna": "^3.22.1",
    "nodemon": "^2.0.4",
    "standardx": "^5.0.0",
    "ts-node": "^9.0.0",
    "typescript": "^4.0.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@myscope/servicea": "file:packages/serviceA",
    "@myscope/serviceb": "file:packages/serviceB",
    "@myscope/servicec": "file:packages/serviceC"
  }
}
